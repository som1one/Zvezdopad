[Unit]
Description=StarsWheel Telegram Bot
After=network.target postgresql.service

[Service]
Type=simple
User=root
WorkingDirectory=/root/starswheelapp
EnvironmentFile=/root/starswheelapp/.env
ExecStart=/usr/bin/python3 /root/starswheelapp/main.py
Restart=always
RestartSec=5
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
